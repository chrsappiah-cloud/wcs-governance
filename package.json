    "db:seed-founder": "echo 'Run supabase/seed-founder.sql in Supabase SQL editor after migrations'"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.8",
    "firebase-admin": "^13.4.0",
    "next": "^15.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "md-to-pdf": "^5.2.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
