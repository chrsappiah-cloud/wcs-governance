{
  "name": "wcs-governance",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "export:rd": "tsx scripts/export-rd-report.ts",
    "export:pdf": "tsx scripts/export-markdown-pdf.ts",
    "export:governance-pdf": "tsx scripts/export-markdown-pdf.ts governance",
    "prepare:pdf": "npx puppeteer browsers install chrome",
    "verify:setup": "tsx scripts/verify-setup.ts",
    "go-live": "tsx scripts/go-live.ts",
    "test:unit": "node --import tsx --test tests/unit/*.test.ts",
    "test:e2e": "node --import tsx --test tests/e2e.test.ts",
    "test:stack": "tsx scripts/test-stack.ts",
    "test": "npm run test:unit && npm run test:stack",
    "test:all": "npm run test:unit && npm run test:stack && npm run test:e2e",
    "backup:firebase": "tsx scripts/backup-to-firebase.ts",
